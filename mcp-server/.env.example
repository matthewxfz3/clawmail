# Mail domain (pre-configured - agents only pick local part)
DOMAIN=mail.yourdomain.com

# Stalwart Mail Server
STALWART_URL=http://localhost:8080
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=changeme

# API key for MCP callers (comma-separated, all treated as admin — legacy)
MCP_API_KEYS=key1,key2

# API key map with permission levels (JSON, takes precedence over MCP_API_KEYS)
# MCP_API_KEY_MAP=[{"key":"admin-key","role":"admin"},{"key":"user-key","role":"user","account":"agent@mail.yourdomain.com"}]

# Rate limiting (Redis URL, optional - uses in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Attachment size limit in bytes (default 25MB)
MAX_ATTACHMENT_BYTES=26214400

# SendGrid verified sender (must be verified in SendGrid dashboard)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_VERIFIED_SENDER=noreply@yourdomain.com

# Dashboard login (GET /dashboard)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Port for MCP server
PORT=3000
