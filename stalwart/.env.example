# Copy this file to .env and fill in real values before running locally.
# In production (Cloud Run / GKE) inject these as Secret Manager secrets.

DOMAIN=mail.yourdomain.com

# Cloud SQL (PostgreSQL) connection
DB_HOST=localhost
DB_PASSWORD=changeme

# GCS S3-compatible HMAC credentials
GCS_BUCKET=your-clawmail-bucket
GCS_ACCESS_KEY=your-hmac-access-key
GCS_SECRET_KEY=your-hmac-secret-key

# Twilio SendGrid API key (used as SMTP password; username is always "apikey")
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Built-in admin account password
STALWART_ADMIN_SECRET=changeme
